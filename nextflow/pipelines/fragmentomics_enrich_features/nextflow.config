params {
    samplesheet  = ""
    outdir       = "results"

    // Which filter to run: "filter_bed" | "filter_flen" | "filter_nd"
    mode         = "filter_flen"

    // filter_bed: path to a BED file to intersect against
    bed_file     = ""

    // filter_nd: nucleosome-distance range (columns 6/7 of FLEN_EM_ND.tsv)
    nd_min       = 0
    nd_max       = 50

    // Internal — do not expose to users
    projectdir   = "/Users/hieunguyen/src/tmp/Fragmentomics_TF_and_enrich_features"
}

docker {
    enabled    = true
    runOptions = "-v ${params.projectdir}:${params.projectdir} -v /mnt:/mnt -v /localtmp:/localtmp"
}

process {
    container = "tronghieunguyen/wgs-fragmentomics-features:latest"
}
