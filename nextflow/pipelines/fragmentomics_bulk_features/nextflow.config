params {
    samplesheet  = ""
    // "from_bam"       — frag bed.gz → compute EM+ND → bulk features
    // "from_frag_file" — pre-computed FLEN_EM_ND.tsv → bulk features only
    mode         = "from_bam"
    outdir       = "results"

    // Internal — do not expose to users
    projectdir   = "/Users/hieunguyen/src/tmp/Fragmentomics_TF_and_enrich_features"

    // Resource paths
    ref_genome    = "/mnt/NFS_190T/DATA_HIEUNGUYEN/resources/hg19.fa"
    nucleosome_ref = "/mnt/NFS_190T/DATA_HIEUNGUYEN/resources/rpr_map_Budhraja_STM2023.bed"

    // Feature params
    min_flen     = 50
    max_flen     = 350
}

docker {
    enabled    = true
    runOptions = "-v ${params.projectdir}:${params.projectdir} -v /mnt:/mnt -v /localtmp:/localtmp"
}

process {
    container = "tronghieunguyen/wgs-fragmentomics-features:latest"
}
