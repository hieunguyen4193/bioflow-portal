params {
    samplesheet  = ""
    // "from_bam"       — BAM file → step01 extracts fragment file → bulk features
    // "from_frag_file" — pre-computed FLEN_EM_ND.tsv → bulk features only
    mode         = "from_bam"
    outdir       = "results"

    // Internal — do not expose to users
    projectdir            = "/Users/hieunguyen/src/tmp/Fragmentomics_TF_and_enrich_features"
    publish_intermediates = false   // suppress step01 outputs; only bulk feature results are kept

    // Internal — scripts are bundled in the TF features pipeline directory
    projectdir    = "/Users/hieunguyen/src/bioflow-portal/nextflow/pipelines/fragmentomics_TF_features"

    // Resource directory (must contain hg19.fa, rpr_map_Budhraja_STM2023.bed)
    resource_dir  = "/mnt/NFS_190T/DATA_HIEUNGUYEN/resources"

    // Step01 params (used in from_bam mode)
    nthreads     = 4
    short_lower  = 50
    short_upper  = 150
    long_lower   = 151
    long_upper   = 350
    min_flen     = 50
    max_flen     = 350
    markdup      = "false"
    input_type   = "bam"
}

docker {
    enabled    = true
    runOptions = "-v ${params.projectdir}:${params.projectdir} -v ${params.resource_dir}:${params.resource_dir}"
}

process {
    container = "tronghieunguyen/wgs-fragmentomics-features:latest"
}
