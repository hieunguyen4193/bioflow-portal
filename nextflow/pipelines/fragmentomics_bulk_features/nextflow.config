params {
    samplesheet  = ""
    // "from_bam"       — frag bed.gz → compute EM+ND → bulk features
    // "from_frag_file" — pre-computed FLEN_EM_ND.tsv → bulk features only
    mode         = "from_bam"
    outdir       = "results"

    // Internal — do not expose to users
    projectdir   = "/Users/hieunguyen/src/tmp/Fragmentomics_TF_and_enrich_features"

    // Resource directory (must contain hg19.fa, rpr_map_Budhraja_STM2023.bed)
    resource_dir  = "/mnt/NFS_190T/DATA_HIEUNGUYEN/resources"

    // Feature params
    min_flen     = 50
    max_flen     = 350
}

docker {
    enabled    = true
    runOptions = "-v ${params.projectdir}:${params.projectdir} -v ${params.resource_dir}:${params.resource_dir}"
}

process {
    container = "tronghieunguyen/wgs-fragmentomics-features:latest"
}
