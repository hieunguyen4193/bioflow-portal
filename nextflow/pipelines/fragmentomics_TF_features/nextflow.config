params {
    // ── Input ──────────────────────────────────────────────────────────────
    samplesheet   = ""
    input_type    = "bam"    // "bam" or "cram"
    outdir        = "results"

    // ── Internal — not exposed to users ───────────────────────────────────
    // Points to the checked-out Fragmentomics source repository.
    // Change this when the repo moves; never surface it in the UI.
    projectdir    = "/Users/hieunguyen/src/tmp/Fragmentomics_TF_and_enrich_features"

    // ── Resource paths (configure for your server) ─────────────────────────
    ref_genome    = "/mnt/NFS_190T/DATA_HIEUNGUYEN/resources/hg19.fa"
    tfbs_dir      = "/mnt/NFS_190T/DATA_HIEUNGUYEN/resources/preprocessed_resources/TFBS"
    nucleosome_ref = "/mnt/NFS_190T/DATA_HIEUNGUYEN/resources/rpr_map_EXP0779.bed"

    // ── Step toggles ───────────────────────────────────────────────────────
    run_step01    = "true"
    run_step02    = "true"
    run_step03    = "true"
    run_step04    = "true"
    run_step05    = "true"
    run_step06    = "true"

    // ── Step 01 params ─────────────────────────────────────────────────────
    nthreads      = 4
    short_lower   = 50
    short_upper   = 150
    long_lower    = 151
    long_upper    = 350
    min_flen      = 50
    max_flen      = 350
    markdup       = "false"
}

docker {
    enabled    = true
    // Mount the source repo and server NFS paths into the container.
    // If the repo moves, update params.projectdir above — this line stays the same.
    runOptions = "-v ${params.projectdir}:${params.projectdir} -v /mnt:/mnt -v /localtmp:/localtmp"
}

process {
    container = "tronghieunguyen/wgs-fragmentomics-features:latest"

    withName: 'CRAM_TO_BAM' {
        cpus   = 4
        memory = '8 GB'
    }
    withName: 'PROCESS_BAM' {
        cpus   = { params.nthreads as int }
        memory = '16 GB'
    }
    withName: 'CHROMOSOME_FEATURES' {
        cpus   = 2
        memory = '8 GB'
    }
    withName: 'CNA_FEATURES' {
        cpus   = 2
        memory = '16 GB'
    }
    withName: 'COVERAGE_PROFILE' {
        cpus   = 4
        memory = '16 GB'
    }
    withName: 'WPS_IFS_FDI' {
        cpus   = 4
        memory = '16 GB'
    }
    withName: 'RFE_FEATURES' {
        cpus   = 4
        memory = '16 GB'
    }
}
