# Absolute path to the data directory on the HOST machine.
# Used by `docker run -v` calls made from inside the backend container.
# Set this to: /absolute/path/to/bioflow-portal/data
BIOFLOW_DATA_DIR=/absolute/path/to/bioflow-portal/data
BIOFLOW_R_SCRIPTS=/absolute/path/to/bioflow-portal/backend/app/r_scripts
