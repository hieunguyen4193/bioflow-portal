# Absolute path to the directory where uploads, pipeline results, and Explore
# session data are stored. Can be anywhere on the host — does NOT need to live
# inside this repo (e.g. a dedicated disk/volume: /mnt/bioflow-data).
# This same path is used both for docker-compose volume mounts and for
# `docker run -v` calls made from inside the backend container.
BIOFLOW_DATA_DIR=/absolute/path/to/your/data/dir

# Absolute host path to the backend's R scripts directory (used so spawned
# R containers can read them via a host-path volume mount).
BIOFLOW_R_SCRIPTS=/absolute/path/to/bioflow-portal/backend/app/r_scripts

# Docker image used for all R analysis jobs (pathway analysis, CellChat).
PIPELINE_IMAGE=pipeline-portal/r-pipeline:latest
